# ─── Server Configuration ──────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database Configuration ────────────────────────────────────
# For local development: mongodb://127.0.0.1:27017/edusync-ai
# For production: Use MongoDB Atlas connection string
# Example: mongodb+srv://username:password@cluster.mongodb.net/edusync-ai?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/edusync-ai

# ─── JWT Secret Key ────────────────────────────────────────────
# IMPORTANT: Generate a strong random secret for production
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ─── AI Service API Key ────────────────────────────────────────
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# ─── CORS Configuration ────────────────────────────────────────
# Comma-separated list of allowed origins (frontend URLs)
# For local development:
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# For production (example):
# ALLOWED_ORIGINS=https://edusync.onrender.com,https://edusync.yourdomain.com

# ─── ML Configuration ──────────────────────────────────────────
ENABLE_ML=true
MODEL_VERSION=v1
ML_CONFIDENCE_THRESHOLD=0.65

# ─── Exam Security Mode ────────────────────────────────────────
# STRICT_EXAM_MODE=true: Single violation = immediate auto-submit, no warnings
# STRICT_EXAM_MODE=false: Threshold-based (3 violations = auto-submit)
STRICT_EXAM_MODE=true
