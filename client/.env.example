# ─── Frontend Environment Variables ───────────────────────────
# Backend API URL (no trailing slash)

# For local development:
VITE_API_URL=http://localhost:5000

# For production (Render example):
# VITE_API_URL=https://edusync-backend.onrender.com

# NOTE: After changing this file, restart your development server
# The VITE_ prefix is required for Vite to expose the variable to the browser
